{
  "name": "cloud-vscode-theme",
  "displayName": "Cloud Theme",
  "description": "Cloud theme with light and dark palette.",
  "publisher": "vallyscode",
  "version": "0.0.13",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "galleryBanner": {
    "color": "#f1f1f1",
    "theme": "light"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vallyscode/cloud-vscode-theme.git"
  },
  "keywords": [ "theme", "light", "cloud", "cloud light" ],
  "homepage": "https://github.com/vallyscode/cloud-vscode-theme",
  "bugs": {
    "url": "https://github.com/vallyscode/cloud-vscode-theme/issues"
  },
  "contributes": {
    "themes": [
      {
        "label": "Cloud Light",
        "uiTheme": "vs",
        "path": "./themes/cloud-light-color-theme.json"
      },
      {
        "label": "Cloud Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/cloud-dark-color-theme.json"
